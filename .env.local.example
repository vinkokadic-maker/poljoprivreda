# Kopiraj ovu datoteku u novu pod imenom  .env.local  i upiši svoje vrijednosti.
# Nalaze se u Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TVOJ-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tvoj-anon-public-kljuc

# Anthropic (Claude) API ključ za čitanje dokumenata.
# TAJNO - bez NEXT_PUBLIC prefiksa (koristi se samo na serveru).
# Ključ nabaviš na https://console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase service role ključ - za dodavanje korisnika sa servera.
# VRLO TAJNO (ima puni pristup bazi). Samo server, nikad u pregledniku.
# Nalazi se u Supabase: Project Settings -> API -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
